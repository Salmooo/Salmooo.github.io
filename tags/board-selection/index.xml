          &lt;td&gt;+&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
          &lt;td&gt;++&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
          &lt;td&gt;-&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;IP 评估&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
          &lt;td&gt;++&lt;/td&gt;
          &lt;td&gt;+&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;ECO 回归&lt;/td&gt;
          &lt;td&gt;+&lt;/td&gt;
          &lt;td&gt;++&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
          &lt;td&gt;+&lt;/td&gt;
          &lt;td&gt;+&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
          &lt;td&gt;++&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;驱动测试&lt;/td&gt;
