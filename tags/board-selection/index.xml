          &lt;td&gt;++&lt;/td&gt;
          &lt;td&gt;++&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
          &lt;td&gt;=&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;软件验证&lt;/td&gt;
